rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() == 'admin';
    }

    function isAuthor() {
      return isSignedIn() && (getUserRole() == 'author' || getUserRole() == 'admin');
    }

    // ─── Posts ───────────────────────────────────────────────────────────────

    match /posts/{postId} {
      // Anyone can read published posts
      allow read: if resource.data.status == 'published'
                  || (isSignedIn() && (isAuthor() || isAdmin()));

      // Only admins and authors can create/update
      allow create: if isAuthor()
                    && request.resource.data.keys().hasAll(['title', 'content', 'category', 'status', 'author']);

      allow update: if isAdmin()
                    || (isAuthor() && resource.data.authorId == request.auth.uid);

      allow delete: if isAdmin();

      // ─── Comments sub-collection ──────────────────────────────────────────
      match /comments/{commentId} {
        // Anyone can read comments
        allow read: if true;

        // Signed-in users and guests (with name) can post comments
        allow create: if request.resource.data.keys().hasAll(['author', 'content', 'postId', 'createdAt'])
                      && request.resource.data.author is string
                      && request.resource.data.author.size() >= 2
                      && request.resource.data.content is string
                      && request.resource.data.content.size() >= 3
                      && request.resource.data.content.size() <= 2000;

        // Only the comment owner (via authorId) or admins can delete
        allow delete: if isAdmin()
                      || (isSignedIn() && resource.data.authorId == request.auth.uid);

        allow update: if false; // Comments are immutable
      }
    }

    // ─── Daily Editions ──────────────────────────────────────────────────────

    match /editions/{editionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Subscribers ─────────────────────────────────────────────────────────

    match /subscribers/{docId} {
      // Anyone can subscribe
      allow create: if request.resource.data.keys().hasAll(['email', 'subscribedAt'])
                    && request.resource.data.email is string
                    && request.resource.data.email.matches('.*@.*\\..*');
      allow read, update, delete: if isAdmin();
    }

    // ─── Users / Profiles ────────────────────────────────────────────────────

    match /users/{userId} {
      // Users can read their own profile; admins can read all
      allow read: if isOwner(userId) || isAdmin();

      // Users can create/update their own profile (but NOT change role)
      allow create: if isOwner(userId)
                    && (!request.resource.data.keys().hasAny(['role'])
                        || request.resource.data.role == 'guest');

      allow update: if (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))
                    || isAdmin();

      allow delete: if isAdmin();
    }

    // ─── News Agent Jobs ─────────────────────────────────────────────────────

    match /newsAgentJobs/{jobId} {
      allow read: if isAdmin() || isAuthor();
      allow write: if isAdmin();
    }

    // ─── Notifications ───────────────────────────────────────────────────────

    match /notifications/{notifId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Subscriptions / Plans ───────────────────────────────────────────────

    match /subscriptions/{subId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

  }
}
