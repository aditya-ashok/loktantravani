rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() == 'admin';
    }

    function isAuthor() {
      return isSignedIn() && (getUserRole() == 'author' || getUserRole() == 'admin');
    }

    // ─── Posts ───────────────────────────────────────────────────────────────

    match /posts/{postId} {
      // Anyone can read posts (published or draft for admin)
      allow read: if true;

      // Only signed-in users can create posts
      allow create: if isSignedIn();

      // Only signed-in users can update
      allow update: if isSignedIn();

      // Only admins can delete posts
      allow delete: if isAdmin();

      // ─── Comments sub-collection ──────────────────────────────────────────
      match /comments/{commentId} {
        // Anyone can read comments
        allow read: if true;

        // Signed-in users and guests (with name) can post comments
        allow create: if request.resource.data.keys().hasAll(['author', 'content', 'postId', 'createdAt'])
                      && request.resource.data.author is string
                      && request.resource.data.author.size() >= 2
                      && request.resource.data.content is string
                      && request.resource.data.content.size() >= 3
                      && request.resource.data.content.size() <= 2000;

        // Only the comment owner (via authorId) or admins can delete
        allow delete: if isAdmin()
                      || (isSignedIn() && resource.data.authorId == request.auth.uid);

        allow update: if false; // Comments are immutable
      }
    }

    // ─── Daily Editions ──────────────────────────────────────────────────────

    match /editions/{editionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Subscribers ─────────────────────────────────────────────────────────

    match /subscribers/{docId} {
      // Anyone can subscribe
      allow create: if request.resource.data.keys().hasAll(['email', 'subscribedAt'])
                    && request.resource.data.email is string
                    && request.resource.data.email.matches('.*@.*\\..*');
      allow read, update, delete: if isAdmin();
    }

    // ─── Users / Profiles ────────────────────────────────────────────────────

    match /users/{userId} {
      // Signed-in users can read any profile (needed for email lookup on first login)
      allow read: if isSignedIn();

      // Users can create their own profile or migrate email-keyed profiles
      allow create: if isSignedIn()
                    && request.resource.data.email == request.auth.token.email;

      // Owner can update (but not role); admins can update anything
      allow update: if (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))
                    || isAdmin();

      // Only the user themselves or admins can delete a profile
      allow delete: if request.auth.uid == userId || isAdmin();
    }

    // ─── News Agent Jobs ─────────────────────────────────────────────────────

    match /newsAgentJobs/{jobId} {
      allow read: if isAdmin() || isAuthor();
      allow write: if isAdmin();
    }

    // ─── Notifications ───────────────────────────────────────────────────────

    match /notifications/{notifId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── FCM Tokens ─────────────────────────────────────────────────────────

    match /fcm_tokens/{tokenId} {
      // Server-side API handles reads/writes; anyone can register a token
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ─── Subscriptions / Plans ───────────────────────────────────────────────

    match /subscriptions/{subId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

  }
}
